# PolicyAssist / monitoring service — environment template.
# Copy to .env and fill in real values. Do NOT commit .env.

# --- PolicyAssist (reference client) ---

# Anthropic API key for PolicyAssist to call Claude.
ANTHROPIC_API_KEY=

# --- Monitoring client (OTel) ---

# OTLP endpoint the monitoring client ships spans to.
# Local SigNoz default: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OTLP protocol — http/protobuf is recommended for local dev.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional bearer token if the OTLP endpoint is behind auth.
# Format: "Authorization=Bearer <token>"
OTEL_EXPORTER_OTLP_HEADERS=

# Service name attached to every span — used to distinguish apps
# on the per-app cost dashboard.
OTEL_SERVICE_NAME=policyassist

# --- Session cookie signing key (Slice A) ---
# Any long random string; keep out of git. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Optional: override per-session history storage root (defaults to
# policyassist/chat_log/ relative to the app module).
POLICYASSIST_HISTORY_ROOT=
